# Copie este arquivo para .env e preencha com suas chaves
BINANCE_API_KEY=sua_api_key_aqui
BINANCE_API_SECRET=sua_secret_key_aqui

# Telegram (opcional - para receber alertas)
TELEGRAM_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Configurações do bot
MODO=simulacao        # simulacao ou real
BANCA=1000            # valor total da sua banca em USDT
ALAVANCAGEM=20        # 10 ou 20
RISCO_POR_TRADE=0.02  # 2% da banca por operação
MARGEM_MAX=0.06       # máximo 6% da banca em margem ao mesmo tempo
STOP_LOSS_ROI=2.0     # stop loss em 200% do ROI da margem
TAKE_PROFIT_ROI=5.0   # take profit em 500% do ROI da margem
